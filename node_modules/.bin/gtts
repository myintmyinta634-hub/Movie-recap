#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*) basedir=`cygpath -w "$basedir"`;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/ubuntu/Movie-recap-web/node_modules/.pnpm/gtts@0.2.1/node_modules/gtts/bin/node_modules:/home/ubuntu/Movie-recap-web/node_modules/.pnpm/gtts@0.2.1/node_modules/gtts/node_modules:/home/ubuntu/Movie-recap-web/node_modules/.pnpm/gtts@0.2.1/node_modules:/home/ubuntu/Movie-recap-web/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/ubuntu/Movie-recap-web/node_modules/.pnpm/gtts@0.2.1/node_modules/gtts/bin/node_modules:/home/ubuntu/Movie-recap-web/node_modules/.pnpm/gtts@0.2.1/node_modules/gtts/node_modules:/home/ubuntu/Movie-recap-web/node_modules/.pnpm/gtts@0.2.1/node_modules:/home/ubuntu/Movie-recap-web/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../gtts/bin/gtts" "$@"
else
  exec node  "$basedir/../gtts/bin/gtts" "$@"
fi
